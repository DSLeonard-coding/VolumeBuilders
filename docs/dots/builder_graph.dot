digraph fake_hierarchy {
    size="12,";
    rankdir = BT; // bottom to top

    node [shape = box];

    subgraph cluster_row1 {
    label = "Structures";
    nodesep = 2.0;
    StructureBuilder;
    subgraph cluster_row2 {
        label = "Builders";
        VolumeBuilder;
        RZBuilder;
        BoxBuilder;
        FromG4VSolid;
        rank = same;
    }
    Assembly;
    dummy;
    rank = same;
    }


    //subgraph cluster_row3 {
 //   label="FromG4VSolid Factory";
 //   rank=same;
 // }

subgraph cluster_row3 {
    label = "Structure Factories"
    subgraph cluster_row4 {
        label = "Volume Builder Factories";
        "CreateFromG4VSolid()";
        "CreateBoxBuilder()";
        "CreatePolycone()";
        "CreatePolyhedra()";
        "CreateCylinder()";
        rank = same;
    }
    "CreateAssembly()";
}

subgraph side_comments {
    label ="";
    rankdir=TB;
    style = invis;
    builderComment;
    concreteBuilderComment;
    structureComment;
    factoryComment;
    builderComment -> concreteBuilderComment-> factoryComment [style = invis];
    structureComment-> builderComment  [style = invis];
}

    // edges between nodes
     dummy [label = "", shape = box, width = 0.5; style = invis];
    structureComment [label="Structures are a common view on builders and assemblies.\n  They can have VisAtts etc. set, hierarchical application \n of offset,  rotation, and finally placement", shape=plaintext, fontcolor=gray30, fontsize=13, width=0, height=0]
    structureComment -> StructureBuilder [color = gray30];
    builderComment [label="VolumeBuilder allows operating on collections \n of different  concrete builders.  This view allows all \n operations except initial solid configuration.", shape=plaintext, fontcolor=gray30, fontsize=13, width=0, height=0]
    builderComment -> VolumeBuilder [color = gray30];
    concreteBuilderComment [label="Specialized builders are just what factories return.\n  They do everything, solid configuration, boolean, \n transforms, logical construction, \n visAtts, ect, and placment", shape=plaintext, fontcolor=gray30, fontsize=13, width=0, height=0]
    concreteBuilderComment -> RZBuilder [color = gray30];
    factoryComment [label="Factories are the basic builder interferace,\n starting a fluent builder chain \n that can do everything.", shape=plaintext, fontcolor=gray30, fontsize=13, width=0, height=0]
    factoryComment -> "CreateCylinder()" [color = gray30];
    StructureBuilder -> VolumeBuilder;
    StructureBuilder -> dummy [style = invis];
    StructureBuilder -> Assembly;
    dummy -> "CreateFromG4VSolid()" [style = invis];
    VolumeBuilder -> RZBuilder;
    VolumeBuilder -> "FromG4VSolid";
    VolumeBuilder -> "BoxBuilder";
    FromG4VSolid -> "CreateFromG4VSolid()";
    RZBuilder -> "CreatePolycone()";
    RZBuilder -> "CreatePolyhedra()";
    RZBuilder -> "CreateCylinder()";
    BoxBuilder -> "CreateBoxBuilder()";
    Assembly -> "CreateAssembly()";
}
