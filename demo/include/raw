    {
      return true;
    }
  }
  return false;
}
inline G4bool G4DataVector::remove(const G4double& a)
{
  G4bool found = false;
  for(auto i = cbegin(); i != cend(); ++i)
  {
    if(!(*i != a))
    {
      erase(i);
      found = true;
      break;
    }
  }
  return found;
}
inline std::size_t G4DataVector::removeAll(const G4double& a)
{
  std::size_t ptn = 0;
  for(auto i = cbegin(); i != cend(); ++i)
  {
    if(!(*i != a))
    {
      erase(i);
      ++ptn;
      --i;
    }
  }
  return ptn;
}
