      retVal = substr(i, length() - i);
    }
    break;
    case trailing:
    {
      G4int j = 0;
      for(j = G4int(length() - 1); j >= 0; --j)
      {
        if(std_string::operator[](j) != ch)
        {
          break;
        }
      }
      retVal = substr(0, j + 1);
    }
    break;
    case both:
    {
      for(i = 0; i < length(); ++i)
      {
        if(std_string::operator[](i) != ch)
        {
          break;
        }
