}
inline
G4double G4AffineTransform::operator [] (const G4int n) const
{
  G4double v = 0.0;
  switch(n)
  {
    case 0:
            v=rxx;
            break;
    case 1:
            v=rxy;
            break;
    case 2:
            v=rxz;
            break;
    case 4:
            v=ryx;
            break;
    case 5:
            v=ryy;
            break;
    case 6:
            v=ryz;
            break;
    case 8:
            v=rzx;
            break;
    case 9:
            v=rzy;
            break;
    case 10:
            v=rzz;
            break;
    case 12:
            v=tx;
            break;
    case 13:
            v=ty;
            break;
    case 14:
            v=tz;
            break;
    case 3:
    case 7:
    case 11:
            break;
    case 15:
            v=1.0;
            break;
  }
  return v;
