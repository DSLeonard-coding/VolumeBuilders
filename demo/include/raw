void G4CountedObject<X>::Release()
{
  if(--fCount == 0)
    delete this;
}
template <class X>
void* G4CountedObject<X>::operator new(std::size_t)
{
  if(aCountedObjectAllocator() == nullptr)
    aCountedObjectAllocator() = new G4Allocator<G4CountedObject<void>>;
