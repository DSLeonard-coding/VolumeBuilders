template <typename T>
T* G4UImessenger::CreateCommand(const G4String& cname, const G4String& dsc)
{
  G4String path;
  if(cname(0) != '/')
  {
    path = baseDirName + cname;
    if(path(0) != '/')
      path = "/" + path;
  }
  T* command = new T(path.c_str(), this);
  command->SetGuidance(dsc.c_str());
  return command;
}
