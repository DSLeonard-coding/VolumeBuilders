inline void G4DynamicParticle::ComputeBeta() const
{
  theBeta = 1.0;
  if(theDynamicalMass > 0.0 && theKineticEnergy < 1000*theDynamicalMass)
  {
    const G4double T = theKineticEnergy/theDynamicalMass;
    theBeta = std::sqrt(T*(T+2.))/(T+1.0);
  }
}
