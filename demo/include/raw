  {
    bin = size_t(std::max(G4Log(theEnergy) * invdBin - baseBin, 0.0));
  }
  else if(type == T_G4PhysicsLinearVector)
  {
    bin = size_t(std::max(theEnergy * invdBin - baseBin, 0.0));
  }
  else
  {
