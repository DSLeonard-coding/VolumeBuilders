      (*_G4cerr_p()) << "theListOfSecondaries is not empty " << std::endl;
      (*_G4cerr_p()) << "All objects in theListOfSecondaries are destroyed!" << std::endl;
    }
    for(G4int index = 0; index < theNumberOfSecondaries; index++)
    {
      if((*theListOfSecondaries)[index])
